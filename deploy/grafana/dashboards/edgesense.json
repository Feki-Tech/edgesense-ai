{
  "uid": "edgesense",
  "title": "EdgeSense AI — fleet & agent",
  "tags": ["edgesense"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uplink",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "edgesense-prom" },
      "targets": [{ "expr": "edgesense_uplink_connected", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Buffered events (store-and-forward)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "edgesense-prom" },
      "targets": [{ "expr": "edgesense_buffer_depth", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 100 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Events delivered upstream",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "edgesense-prom" },
      "targets": [{ "expr": "edgesense_events_published_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Machines reporting",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "edgesense-prom" },
      "targets": [{ "expr": "count(rate(edgesense_readings_scored_total[1m]) > 0) or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Store-and-forward buffer depth",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "edgesense-prom" },
      "targets": [{ "expr": "edgesense_buffer_depth", "legendFormat": "buffered events", "refId": "A" }],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 25 }, "min": 0 }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Readings scored /s (per machine)",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "edgesense-prom" },
      "targets": [{ "expr": "sum by (machine) (rate(edgesense_readings_scored_total[1m]))", "legendFormat": "{{machine}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "min": 0 }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Anomalies /min (per machine)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "edgesense-prom" },
      "targets": [{ "expr": "sum by (machine) (rate(edgesense_anomalies_total[2m])) * 60", "legendFormat": "{{machine}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 }, "min": 0 }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Inference latency",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "edgesense-prom" },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(edgesense_inference_latency_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(edgesense_inference_latency_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
